{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SQL Mate",
  "version": "0.1.0",
  "identifier": "com.sqlmate.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SQL Mate",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg"],
    "publisher": "SQL Mate",
    "category": "DeveloperTool",
    "shortDescription": "Local-first natural-language SQL for your databases.",
    "longDescription": "SQL Mate turns natural-language questions into read-only SQL queries against your database. Row data never leaves your machine. Bring your own LLM key.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
